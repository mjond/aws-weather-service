{
  "name": "aws-weather-service",
  "version": "0.1.0",
  "bin": {
    "aws-weather-service": "bin/aws-weather-service.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"bin/**/*.ts\" \"lib/**/*.ts\" \"lambda/**/*.ts\" \"repositories/**/*.ts\" \"test/**/*.ts\" \"eslint.config.mjs\"",
    "format:check": "prettier --check \"bin/**/*.ts\" \"lib/**/*.ts\" \"lambda/**/*.ts\" \"repositories/**/*.ts\" \"test/**/*.ts\" \"eslint.config.mjs\"",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "2.1023.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.985.0",
    "@aws-sdk/lib-dynamodb": "^3.985.0",
    "aws-cdk-lib": "2.206.0",
    "constructs": "^10.0.0"
  }
}
